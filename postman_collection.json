        {
          "name": "PUT Negative Price",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code should be 400 for invalid input\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(400);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response should not be successful\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Negative price should not be accepted\", function () {\r",
                  "    let responseJson = {};\r",
                  "    \r",
                  "    try {\r",
                  "        responseJson = pm.response.json();\r",
                  "    } catch (e) {\r",
                  "        responseJson = {};\r",
                  "    }\r",
                  "\r",
                  "    if (responseJson.price !== undefined) {\r",
                  "        pm.expect(responseJson.price).to.be.above(0);\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
